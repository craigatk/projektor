{
  "name": "projektor",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "start": "vite serve src --port 1234",
    "build": "yarn clean-dist && vite build src --outDir ../dist",
    "build:dev": "yarn clean-dev-dist && NODE_ENV=development vite build src",
    "format": "prettier --write \"src/**/*.ts*\" \"src/**/*.spec.ts*\" \"cypress/fixtures/**/*.json\" \"cypress/**/*.js\" \"src/**/*.module.css\"",
    "test": "vitest run",
    "test:projektor:ci": "yarn test || yarn projektor-publish --configFile=projektor.jest.json",
    "projektor:jest:ci": "yarn projektor-publish --configFile=projektor.jest.json",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:single": "cypress run -s cypress/integration/attachments.spec.js",
    "cy:test": "yarn clean-results && start-server-and-test start http://localhost:1234 cy:run",
    "cy:test:projektor:ci": "yarn cy:test || yarn projektor-publish --configFile=projektor.cypress.json",
    "projektor:cypress:no-attachments": "projektor-publish --configFile=projektor.cypress.no.attachments.json",
    "projektor:cypress": "env-cmd -f ~/.env projektor-publish --configFile=projektor.cypress.json",
    "projektor:jest": "env-cmd -f ~/.env projektor-publish --configFile=projektor.jest.json",
    "clean-results": "rimraf test-results/*.xml",
    "clean-dist": "rimraf dist",
    "clean-dev-dist": "rimraf dev-dist"
  },
  "devDependencies": {
    "@testing-library/cypress": "10.1.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitest/coverage-v8": "4.1.10",
    "axios-mock-adapter": "2.1.0",
    "chai-colors": "1.0.1",
    "css-mediaquery": "0.1.2",
    "cypress": "15.18.1",
    "del": "8.0.1",
    "env-cmd": "11.0.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "process": "0.11.10",
    "projektor-publish": "3.13.13",
    "resize-observer-polyfill": "1.5.1",
    "rimraf": "6.1.3",
    "start-server-and-test": "3.0.11",
    "typescript": "7.0.2",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wait-for-expect": "4.0.0"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/lab": "6.0.1-beta.36",
    "@mui/material": "9.2.0",
    "@mui/x-date-pickers": "9.9.0",
    "@reach/router": "1.3.4",
    "@types/node": "24.13.3",
    "@types/reach__router": "1.3.15",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axios": "1.18.1",
    "axios-cache-interceptor": "1.12.0",
    "axios-case-converter": "1.1.1",
    "classnames": "2.5.1",
    "lodash": "4.18.1",
    "material-react-table": "3.2.1",
    "moment": "2.30.1",
    "moment-timezone": "0.6.2",
    "pretty-bytes": "7.1.0",
    "react": "19.2.7",
    "react-copy-to-clipboard": "5.1.1",
    "react-dom": "19.2.7",
    "react-scroll": "1.9.3",
    "recharts": "3.9.2",
    "use-query-params": "2.2.2"
  },
  "resolutions": {
    "axios": "1.18.1",
    "qs": "6.15.3"
  }
}
